# =====================================================================
# JVMind Community Edition — 配置示例
# 复制为 .env 后按需修改；社区版单用户、本地优先。
# =====================================================================

# ----- 服务监听 -----
HOST=127.0.0.1
PORT=8000

# ----- OpenAI 兼容接口配置 -----
# 默认使用 DeepSeek（https://api.deepseek.com/v1）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 示例：OpenAI 官方
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 示例：通义千问
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

# 单次 LLM 请求超时（秒）
# OPENAI_TIMEOUT_SECONDS=60

# 用户 BYOK 自定义 Base URL 的白名单（逗号分隔），空值不校验（存在 SSRF 风险）
# OPENAI_BASE_URL_ALLOWLIST=https://api.openai.com,https://api.deepseek.com,https://dashscope.aliyuncs.com

# ----- Agent 行为 -----
MAX_ITERATIONS=10
OPENAI_TEMPERATURE=0.3

# 使用 LangGraph Agent（社区版默认）
# USE_LANGGRAPH_AGENT=1

# python_exec 工具（高危：开启后 Agent 可在服务器执行任意 Python 代码）
# 仅在受控 / 内网 / 容器隔离环境下设为 1
# ENABLE_PYTHON_EXEC=0

# ----- 数据库 -----
# 默认 SQLite；切换 PostgreSQL 只需改连接串
# DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5432/dbname

# ----- 安全 -----
# 落盘 API Key 加密主密钥；强烈建议设置
# openssl rand -hex 32
# CONFIG_ENCRYPTION_KEY=

# Cookie 是否仅限 HTTPS；生产 HTTPS 必须设为 1
# COOKIE_SECURE=0
# CORS 白名单，逗号分隔；空表示同源
# CORS_ALLOWED_ORIGINS=

# ----- Heapdump 分析（可选，需要安装 Eclipse MAT） -----
# 详细部署步骤见 README.md「Heapdump 分析」章节。

# Web / Worker / query-service 共享存储目录
# HEAPDUMP_STORAGE_ROOT=./data/heapdumps
# 上传分块临时目录
# HEAPDUMP_UPLOAD_TMP=/tmp/heapdump-chunks
# MAT 发行版目录（含 plugins/org.eclipse.equinox.launcher_*.jar）
# MAT_HOME=/opt/mat
# 解析器 JVM 堆内存
# MAT_PARSE_XMX=4g
# MAT query-service 地址
# MAT_QUERY_SERVICE_URL=http://127.0.0.1:8090

# Worker 心跳 / 超时
# HEAPDUMP_WORKER_HEARTBEAT_INTERVAL=30
# HEAPDUMP_WORKER_HEARTBEAT_TIMEOUT=300
# HEAPDUMP_WORKER_MAX_ATTEMPTS=3