# =====================================================================
# JVMind Community Edition — Configuration Example
# Copy to .env and modify as needed. Single-user, local-first.
# =====================================================================

# ----- Server -----
HOST=127.0.0.1
PORT=8000

# ----- LLM (OpenAI-compatible API) -----
# Default: DeepSeek (https://api.deepseek.com/v1)
# Leave OPENAI_API_KEY empty if using Ollama locally.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Example: OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Example: Qwen (via Alibaba Cloud)
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

# Example: Ollama (local, zero-cost, no API key needed)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5
# (leave OPENAI_API_KEY empty)

# Per-LLM-call timeout (seconds)
# OPENAI_TIMEOUT_SECONDS=60

# Allowlist for user-configured base URLs (comma-separated).
# Empty = any URL allowed (SSRF risk with public endpoints).
# OPENAI_BASE_URL_ALLOWLIST=https://api.openai.com,https://api.deepseek.com,https://dashscope.aliyuncs.com

# ----- Agent Behavior -----
MAX_ITERATIONS=10
OPENAI_TEMPERATURE=0.3

# python_exec tool (DANGEROUS: enables arbitrary Python execution on the server).
# Only enable in a trusted/containerized environment.
# ENABLE_PYTHON_EXEC=0

# ----- Database -----
# Default: SQLite. Switch to PostgreSQL by changing the connection string.
# DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5432/dbname

# ----- Security -----
# Master key for encrypting API keys at rest. Strongly recommended.
# Generate one with: openssl rand -hex 32
# CONFIG_ENCRYPTION_KEY=

# Whether cookies require HTTPS. Set to 1 in production with HTTPS.
# COOKIE_SECURE=0
# CORS allowed origins (comma-separated). Empty = same-origin only.
# CORS_ALLOWED_ORIGINS=

# ----- Heapdump Analysis (optional, requires Eclipse MAT) -----
# See README.md "Heapdump analysis" section for setup steps.

# Shared storage root for Web / Worker / query-service
# HEAPDUMP_STORAGE_ROOT=./data/heapdumps
# Upload chunk temp directory
# HEAPDUMP_UPLOAD_TMP=/tmp/heapdump-chunks
# MAT installation directory (must contain plugins/org.eclipse.equinox.launcher_*.jar)
# MAT_HOME=/opt/mat
# Parser JVM heap
# MAT_PARSE_XMX=4g
# MAT query-service URL
# MAT_QUERY_SERVICE_URL=http://127.0.0.1:8090

# Worker heartbeat / timeout
# HEAPDUMP_WORKER_HEARTBEAT_INTERVAL=30
# HEAPDUMP_WORKER_HEARTBEAT_TIMEOUT=300
# HEAPDUMP_WORKER_MAX_ATTEMPTS=3
